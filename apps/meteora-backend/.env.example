# Conexão usada pela aplicação em runtime (pooler/PgBouncer, porta 6543)
DATABASE_URL="postgresql://USUARIO:SENHA@HOST.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexão direta usada pelo Prisma CLI para migrations (porta 5432)
DIRECT_URL="postgresql://USUARIO:SENHA@HOST.pooler.supabase.com:5432/postgres"

# Porta em que o servidor NestJS escuta (opcional, padrão 3000)
PORT=3000
